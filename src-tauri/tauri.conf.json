{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "eyeloss",
  "version": "0.1.0",
  "identifier": "com.eyeloss.dev",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "Eyeloss",
        "width": 1400,
        "height": 900,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  }
}
